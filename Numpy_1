        "print(\"\\nSlice arr[2:6] (view only):\")\n",
        "print(slice_part)\n",
        "\n",
        "# -----------------------------\n",
        "# 2. MODIFY ORIGINAL VIA SLICE\n",
        "# -----------------------------\n",
        "arr[2:6] = [30, 40, 50, 60]\n",
        "print(\"\\nAfter modifying arr[2:6]:\")\n",
        "print(arr)\n",
        "\n",
        "# -----------------------------\n",
        "# 3. SHOW SLICE AGAIN\n",
        "# -----------------------------\n",
        "print(\"\\nSlice after modification:\")\n",
        "print(slice_part)"
