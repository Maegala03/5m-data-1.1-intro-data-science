        "import numpy as np\n",
        "\n",
        "# Create array\n",
        "arr = np.arange(10)\n",
        "print(\"Original array:\")\n",
        "print(arr)\n",
        "\n",
        "# -----------------------------\n",
        "# 1. SLICING (just view)\n",
